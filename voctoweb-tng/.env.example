DATABASE_URL="postgresql://voctoweb:voctoweb@localhost:5434/voctoweb"
CDN_URL=https://cdn.media.ccc.de
STATIC_URL=https://static.media.ccc.de/media
# CORS-enabled proxy for subtitle track fetches (the CDN sends no CORS headers)
CORS_URL=https://media.ccc.de/srt
# ElasticSearch URL and index name are both needed otherwise the app will fall back to simple SQL substring matching
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=media-event-production
SERVER_URL=http://localhost:3000
