%video.video{controls: 'controls',
             preload: 'none',
             poster: playlist.poster_url,
             width: width,
             height: height}

  - playlist.playlist.each do |event, recording|
    %source{type: recording.mime_type,
            src: h(recording.url),
            title: event.title.truncate(30),
            data: { id: event.id,
                    title: event.title,
                    poster: event.poster_url,
                    persons: event.persons.join(', '),
                    lang: recording.language,
                    quality: recording.quality_label,
                    mep: { description: event.description } }}

:javascript
  (async function() {
    const video = document.querySelector('video'),
          sources = video.querySelectorAll('source');

    // Empty playlist; don't build the player, would only be a waste of time and error
    if (!sources.length) { return; }

    // mediaelement's playlist plugin needs >= 2 tracks, so we guard against that
    const multitrack = sources.length > 1;

    // Find the <source> for the currently playing track
    function sourceFor(src) {
      const sources = video.querySelectorAll('source');
      for (let i = 0; i < sources.length; i++) {
        if (sources[i].src === src || sources[i].getAttribute('src') === src) { return sources[i]; }
      }
      return null;
    }
    function setText(selector, text) {
      const el = document.querySelector(selector);
      if (el) { el.textContent = text; }
    }

    // Pin the first track's source to a CDN mirror up front (see mejs-player.js).
    await MejsPlayer.pinMirror(sources[0]);

    new MediaElementPlayer(video, MejsPlayer.options({
      showPlaylist: multitrack,
      playlistTitle: "#{playlist.title}",
      autoClosePlaylist: true,
      features: multitrack? [
          'playlistfeature',
          'skipback', 'prevtrack', 'playpause', 'nexttrack', 'jumpforward', 'progress', 'current',
          'duration', 'tracks', 'volume', 'speed',
          'playlist',
          'fullscreen'
        ] :
        [
          'skipback', 'playpause', 'jumpforward', 'progress', 'current',
          'duration', 'tracks', 'volume', 'speed',
          'fullscreen'
        ],
      success: function (mediaElement) {
        mediaElement.addEventListener('play', function () {
          const ev = sourceFor(mediaElement.src);
          if (ev) {
            video.setAttribute('poster', ev.dataset.poster);
            setText('.description', ev.dataset.mepDescription);
            setText('h2.event_title', ev.dataset.title);
            setText('p.persons', ev.dataset.persons);
          }
          if (mediaElement.src.indexOf('://cdn.media.ccc.de') > 0) {
            MirrorbrainFix.selectMirror(mediaElement.src, function(mirror) {
              mediaElement.setSrc(mirror);
              mediaElement.play();
            });
          }
        }, false);
        mediaElement.addEventListener('playing', function () {
          const ev = sourceFor(mediaElement.src);
          if (ev) { MejsPlayer.count(ev.dataset.id, mediaElement.src); }
        }, false);
      }
    }));
  })();
